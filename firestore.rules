rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@cseb.com';
    }

    // Current frontend reads these collections directly.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Transaction logs are admin-facing only. Settlement writes happen from Cloud Functions
    // using the Admin SDK, which bypasses Firestore rules.
    match /transactions/{transactionId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}